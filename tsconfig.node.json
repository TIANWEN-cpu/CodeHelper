{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./out/main",
    "resolveJsonModule": true
  },
  "include": ["electron/**/*", "electron.vite.config.ts"]
}
